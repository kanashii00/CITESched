# Copy this file to config/passwords.yaml and replace the placeholder values.
# Do not commit config/passwords.yaml.

shared:
  mySharedPassword: "change-me"

development:
  database: "your-local-postgres-password"
  redis: "your-local-redis-password"
  serviceSecret: "generate-a-long-random-string"
  emailSecretHashPepper: "generate-a-long-random-string"
  jwtHmacSha512PrivateKey: "generate-a-long-random-string"
  jwtRefreshTokenHashPepper: "generate-a-long-random-string"
  serverSideSessionKeyHashPepper: "generate-a-long-random-string"
  smtpHost: "smtp.gmail.com"
  smtpPort: "587"
  smtpUsername: "your-school-email@gmail.com"
  smtpPassword: "your-gmail-app-password"
  smtpFromEmail: "your-school-email@gmail.com"
  smtpFromName: "CITESched"
  smtpSsl: "false"
  smtpIgnoreBadCert: "false"
  geminiApiKey: "your-gemini-api-key"
  # Optional: add googleClientSecret here for local Google Sign-In.

test:
  database: "your-test-postgres-password"
  redis: "your-test-redis-password"
  emailSecretHashPepper: "generate-a-long-random-string"
  jwtHmacSha512PrivateKey: "generate-a-long-random-string"
  jwtRefreshTokenHashPepper: "generate-a-long-random-string"
  serverSideSessionKeyHashPepper: "generate-a-long-random-string"

staging:
  database: "your-staging-postgres-password"
  serviceSecret: "generate-a-long-random-string"
  emailSecretHashPepper: "generate-a-long-random-string"
  jwtHmacSha512PrivateKey: "generate-a-long-random-string"
  jwtRefreshTokenHashPepper: "generate-a-long-random-string"
  serverSideSessionKeyHashPepper: "generate-a-long-random-string"
  smtpHost: "smtp.gmail.com"
  smtpPort: "587"
  smtpUsername: "your-staging-email@gmail.com"
  smtpPassword: "your-gmail-app-password"
  smtpFromEmail: "your-staging-email@gmail.com"
  smtpFromName: "CITESched"
  smtpSsl: "false"
  smtpIgnoreBadCert: "false"
  geminiApiKey: "your-gemini-api-key"

production:
  database: "your-render-postgres-password"
  serviceSecret: "generate-a-long-random-string"
  emailSecretHashPepper: "generate-a-long-random-string"
  jwtHmacSha512PrivateKey: "generate-a-long-random-string"
  jwtRefreshTokenHashPepper: "generate-a-long-random-string"
  serverSideSessionKeyHashPepper: "generate-a-long-random-string"
  smtpHost: "smtp.gmail.com"
  smtpPort: "587"
  smtpUsername: "your-production-email@gmail.com"
  smtpPassword: "your-gmail-app-password"
  smtpFromEmail: "your-production-email@gmail.com"
  smtpFromName: "CITESched"
  smtpSsl: "false"
  smtpIgnoreBadCert: "false"
  geminiApiKey: "your-gemini-api-key"
  # Optional: add googleClientSecret here after updating allowed origins in Google Cloud.
